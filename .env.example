# PujoPath Kolkata environment example.
# Copy this file to .env.local for development and fill in real secrets there.
# Never commit .env.local.

# MongoDB connection string. Local Mongo works for development; Atlas works too.
MONGODB_URI=mongodb://localhost:27017/pujopath-kolkata

# Public app origin used for canonical URLs, share links, sitemap, and metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Map provider selector: mock, osm, none, google, or mapbox.
# mock is deterministic and safe for local development/tests.
MAP_PROVIDER=mock

# Server-only map key. Do not expose this in client components.
MAPS_SERVER_API_KEY=

# Browser-safe map key, when a display provider needs one.
# Restrict this key by production domain before deployment.
NEXT_PUBLIC_MAPS_BROWSER_KEY=

# Shared plan expiration window in hours. Valid range: 1-720.
SHARED_PLAN_TTL_HOURS=72

# Default data year used by public pages and sample seed data.
NEXT_PUBLIC_DEFAULT_PUJA_YEAR=2026

# Maximum saved stops in My Puja Plan. Valid range: 1-25.
NEXT_PUBLIC_MAX_PLAN_STOPS=8
